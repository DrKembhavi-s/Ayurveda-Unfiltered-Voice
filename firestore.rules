rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'ayurvedaunfiltered@outlook.com';
    }

    match /feedback/{doc} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /ideas/{doc} {
      allow read, create: if true;
      allow update: if request.resource.data.keys().hasOnly(['upvotes']);
      allow delete: if isAdmin();
    }
    match /polls/{doc} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['options']);
    }
    match /forumPosts/{doc} {
      allow read, create: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
      allow delete: if false;
    }
    match /coalitionMembers/{doc} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /campaigns/{doc} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /proposals/{doc} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /accessRequests/{doc} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && resource.data.email == request.auth.token.email);
      allow update: if isAdmin();
      allow delete: if false;
    }
    match /registeredUsers/{doc} {
      allow create: if false;
      allow read: if true;
      allow update, delete: if false;
    }
    match /announcements/{doc} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Stage 1: richer per-user profile, keyed by Firebase Auth UID ──
    match /users/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.verified == false;
      allow read: if resource.data.status == 'active'
                    || (request.auth != null && request.auth.uid == uid)
                    || isAdmin();
      allow update: if isAdmin()
                    || (request.auth != null && request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['display_name','degree','institution','state','registration_number','year','specialization','bio','avatar_url','post_count','idea_count','following_count']))
                    || (request.auth != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['follower_count']));
      allow delete: if isAdmin();
    }

    // ── Stage 1: write-only admin audit trail, no viewer UI ──
    match /adminLog/{doc} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    // ── Stage 2: one-way follow graph ──
    match /follows/{doc} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.follower_uid
                    && request.resource.data.following_uid != request.resource.data.follower_uid;
      allow read: if true;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == resource.data.follower_uid;
    }

    // ── Stage 2: in-app notifications ──
    match /notifications/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.recipient_uid || isAdmin();
    }

    // ── Alumni Tool ──────────────────────────────
    match /alumni_registrations/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    // ─────────────────────────────────────────────

  }
}
